# ──────────────────────────────────────────────────────────────────────────
# Radar — variabili d'ambiente (esempio). Copia in `.env` e compila.
# ──────────────────────────────────────────────────────────────────────────

# Database Postgres (in docker-compose il host è "db")
DATABASE_URL="postgresql://radar:radar@localhost:5432/radar?schema=public"

# App
APP_URL="http://localhost:3000"          # URL pubblico base (per link ricevute/email)
NODE_ENV="development"

# Autenticazione staff (JWT di sessione)
AUTH_SECRET="cambia-questo-con-una-stringa-lunga-e-casuale"
# Admin iniziale creato dal seed
ADMIN_EMAIL="hello@deltasolutions.agency"
ADMIN_PASSWORD="cambia-questa-password"
ADMIN_NAME="Delta Admin"

# Stripe (chiavi TEST)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Resend
RESEND_API_KEY="re_..."
EMAIL_FROM="Delta Solutions <hello@deltasolutions.agency>"

# Motore scadenze: secret per proteggere l'endpoint cron
CRON_SECRET="cambia-questo-secret-del-cron"
