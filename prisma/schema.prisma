// ──────────────────────────────────────────────────────────────────────────
// Radar — Schema dati (Delta Solutions)
// Piattaforma interna per la gestione di abbonamenti, scadenze e pagamenti.
// ──────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────────────────
// ENUM — stati e tipologie
// ──────────────────────────────────────────────────────────────────────────

/// Ruolo dell'utente staff. Per ora solo ADMIN; STAFF predisposto per il futuro.
enum UserRole {
  ADMIN
  STAFF
}

/// Stato del cliente (anagrafica).
enum ClientStatus {
  ATTIVO
  SOSPESO
  CESSATO
}

/// Tipologia del servizio a catalogo.
enum ServiceType {
  DOMINIO
  HOSTING
  SSL
  PRIVACY
  EMAIL
  ALTRO
}

/// Periodicità di fatturazione/rinnovo del servizio.
enum BillingPeriod {
  MENSILE
  ANNUALE
  PERSONALIZZATA
}

/// Stato dell'abbonamento (relazione cliente ↔ servizio).
enum SubscriptionStatus {
  ATTIVO
  IN_SCADENZA
  SCADUTO
  SOSPESO
  RINNOVATO
  CESSATO
}

/// Modalità con cui viene incassato un pagamento.
enum PaymentMethod {
  STRIPE
  MANUALE
}

/// Stato del singolo pagamento.
enum PaymentStatus {
  IN_ATTESA // checkout creato / in attesa di conferma
  CONFERMATO // incassato (webhook Stripe ok oppure registrazione manuale)
  FALLITO // checkout scaduto/annullato o errore
  RIMBORSATO
}

/// Tipo di comunicazione email inviata tramite Resend.
enum NotificationType {
  CONFERMA_ACQUISTO
  PROMEMORIA_30
  PROMEMORIA_15
  PROMEMORIA_7
  SOLLECITO
  CESSAZIONE_MOROSITA
  PREAVVISO_ADDEBITO
}

/// Esito dell'invio email.
enum NotificationStatus {
  INVIATA
  FALLITA
}

// ──────────────────────────────────────────────────────────────────────────
// UTENTI STAFF
// ──────────────────────────────────────────────────────────────────────────

/// Utente staff che accede alla dashboard. Nessuna registrazione pubblica:
/// l'admin iniziale viene creato dal seed.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Pagamenti registrati manualmente da questo utente.
  recordedPayments Payment[] @relation("PaymentRecordedBy")

  @@map("users")
}

// ──────────────────────────────────────────────────────────────────────────
// ANAGRAFICHE — CLIENTI
// ──────────────────────────────────────────────────────────────────────────

/// Cliente: contatto + profilo di fatturazione.
model Client {
  id String @id @default(cuid())

  // Contatto
  name  String // nome referente / contatto
  email String
  phone String?

  // Profilo di fatturazione
  ragioneSociale String? // ragione sociale / denominazione
  partitaIva     String?
  codiceFiscale  String?
  indirizzo      String?
  citta          String?
  cap            String?
  provincia      String?
  paese          String? @default("IT")
  sdi            String? // Codice destinatario SDI (fatturazione elettronica)
  pec            String? // Indirizzo PEC

  // Token pubblico per la pagina "I tuoi dati di fatturazione" e flag che
  // abilita la modifica self-service: parte true (prima modifica sempre
  // consentita), diventa false dopo il primo salvataggio, torna true solo se
  // l'admin invia una nuova richiesta di aggiornamento dati.
  dataEditToken    String?  @unique
  dataEditUnlocked Boolean  @default(true)

  status ClientStatus @default(ATTIVO)
  note   String?

  // Riferimento al customer Stripe (per riutilizzo dei dati di pagamento).
  stripeCustomerId String? @unique
  // Metodo di pagamento salvato per gli addebiti automatici (SetupIntent).
  stripeDefaultPaymentMethodId String?

  // Momento di invio della mail di benvenuto (una sola volta per cliente).
  welcomeEmailSentAt DateTime?

  subscriptions      Subscription[]
  consentLogs        ConsentLog[]
  autoChargeRequests AutoChargeRequest[]
  dataChangeLogs     ClientDataChangeLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@map("clients")
}

/// Registro delle modifiche ai dati di fatturazione effettuate dal cliente
/// tramite la pagina pubblica self-service (o dall'admin). `changes` contiene
/// il diff prima/dopo per ogni campo modificato.
model ClientDataChangeLog {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  changedBy String   @default("client")
  changes   Json
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([clientId])
  @@map("client_data_change_logs")
}

// ──────────────────────────────────────────────────────────────────────────
// RICHIESTE DI ATTIVAZIONE RINNOVO AUTOMATICO (selettive, multi-servizio)
// ──────────────────────────────────────────────────────────────────────────

/// Richiesta di attivazione del rinnovo automatico per un SOTTOINSIEME ESPLICITO
/// di servizi del cliente, scelto dall'admin. Il cliente, aprendo il link
/// pubblico, autorizza esattamente quei servizi (itemIds), non tutti. Sostituisce
/// il meccanismo cumulativo basato su SubscriptionItem.autoChargeSetupToken.
model AutoChargeRequest {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  token    String @unique @default(cuid())
  // id dei SubscriptionItem inclusi in questa specifica richiesta.
  itemIds  String[]
  // Valorizzato quando la richiesta è stata completata (carta registrata).
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  activationReminders AutoChargeActivationReminder[]

  @@index([clientId])
  @@map("auto_charge_requests")
}

/// Traccia i solleciti di attivazione già inviati per una richiesta, per soglia
/// oraria (12h/24h), così da non reinviare lo stesso sollecito due volte.
model AutoChargeActivationReminder {
  id                  String            @id @default(cuid())
  autoChargeRequestId String
  autoChargeRequest   AutoChargeRequest @relation(fields: [autoChargeRequestId], references: [id], onDelete: Cascade)
  hoursMark           Int // es. 12 o 24
  sentAt              DateTime          @default(now())

  @@unique([autoChargeRequestId, hoursMark])
  @@map("auto_charge_activation_reminders")
}

// ──────────────────────────────────────────────────────────────────────────
// CONSENSI LEGALI
// ──────────────────────────────────────────────────────────────────────────

/// Traccia l'accettazione di Privacy Policy e Termini da parte del cliente,
/// con la versione del testo accettata (per gestire futuri aggiornamenti).
model ConsentLog {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type       String   @default("PRIVACY_TC")
  version    String // es. "2026-07-02"
  acceptedAt DateTime @default(now())
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([clientId])
  @@map("consent_logs")
}

// ──────────────────────────────────────────────────────────────────────────
// SERVIZI — CATALOGO
// ──────────────────────────────────────────────────────────────────────────

/// Catalogo riusabile dei servizi vendibili in abbonamento.
model Service {
  id          String      @id @default(cuid())
  name        String
  type        ServiceType
  description String?

  // Importi in centesimi per evitare problemi di arrotondamento.
  priceCents Int // prezzo di vendita
  costCents  Int    @default(0) // costo fornitore (per calcolo margine)
  currency   String @default("eur")

  billingPeriod    BillingPeriod
  customPeriodDays Int? // valorizzato solo se billingPeriod = PERSONALIZZATA

  autoRenew Boolean @default(true)
  active    Boolean @default(true)

  // Incremento percentuale applicato al prezzo a ogni rinnovo (5 = +5%).
  renewalIncreasePercent Int @default(0)

  subscriptionItems SubscriptionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([active])
  @@map("services")
}

// ──────────────────────────────────────────────────────────────────────────
// ABBONAMENTI
// ──────────────────────────────────────────────────────────────────────────

/// Abbonamento: contenitore per un cliente, dentro cui vivono N servizi
/// (SubscriptionItem), ciascuno con propria scadenza/prezzo/stato indipendenti.
model Subscription {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  notes String?

  // Se true, ai pagamenti Stripe di questo contenitore viene aggiunto il
  // costo di servizio Radar (1,5% del totale servizi). Spunta a livello di
  // contenitore, applicata solo ai pagamenti con metodo STRIPE.
  serviceFeeEnabled Boolean @default(false)

  items    SubscriptionItem[]
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@map("subscriptions")
}

/// Riga di servizio dentro un abbonamento: propria scadenza, prezzo, stato e
/// addebito automatico indipendenti. È l'unità di rinnovo e di scadenza.
model SubscriptionItem {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  serviceId      String
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  status    SubscriptionStatus @default(ATTIVO)
  startDate DateTime           @default(now())
  endDate   DateTime // data di scadenza corrente della riga

  // Quantità del servizio in questa riga: moltiplica priceCents per ottenere
  // l'importo effettivo della riga (es. 3 caselle email a 10€ = 30€).
  quantity  Int                @default(1)

  // Snapshot economico al momento della sottoscrizione della riga.
  priceCents       Int
  currency         String        @default("eur")
  billingPeriod    BillingPeriod
  customPeriodDays Int?

  // Data dell'ultimo rinnovo confermato per questa riga (null = mai rinnovato).
  lastRenewalAt DateTime?

  // Rinnovo automatico con addebito ricorrente (Setup Intent + off_session).
  autoChargeEnabled       Boolean   @default(false)
  autoChargeEndDate       DateTime?
  autoChargeFailCount     Int       @default(0)
  autoChargeLastAttemptAt DateTime?
  // Token pubblico per la pagina self-service di attivazione (con gate consenso).
  autoChargeSetupToken    String?   @unique

  notes String?

  paymentItems  PaymentItem[]
  notifications NotificationLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subscriptionId])
  @@index([serviceId])
  @@index([status])
  @@index([endDate])
  @@map("subscription_items")
}

// ──────────────────────────────────────────────────────────────────────────
// PAGAMENTI
// ──────────────────────────────────────────────────────────────────────────

/// Pagamento collegato a un abbonamento. Può raggruppare più righe di servizio
/// (PaymentItem) con scadenza comune in un unico addebito, ma ciascuna riga
/// resta stornabile singolarmente.
model Payment {
  id             String       @id @default(cuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  amountCents Int // somma dei PaymentItem + eventuale costo di servizio
  // Costo di servizio Radar (1,5%) applicato SOLO ai pagamenti Stripe quando
  // Subscription.serviceFeeEnabled è true. NON è un PaymentItem: è un importo
  // aggiuntivo incluso in amountCents ma non stornabile singolarmente.
  serviceFeeCents Int       @default(0)
  // Quota di serviceFeeCents già resa al cliente tramite storni (parziali o
  // totali). Consente di calcolare il residuo di costo di servizio ancora
  // rimborsabile su storni parziali sequenziali dello stesso pagamento.
  refundedServiceFeeCents Int @default(0)
  currency    String        @default("eur")
  method      PaymentMethod
  // Stato aggregato indicativo: la fonte di verità granulare è PaymentItem.status.
  status      PaymentStatus @default(IN_ATTESA)

  paidAt DateTime?

  // Riferimenti Stripe.
  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String? @unique

  // Token pubblico per la pagina intermedia di pagamento con gate di consenso.
  payToken String @unique @default(cuid())

  // Scadenza della Stripe Checkout Session corrente (per sapere se il link è
  // ancora valido) e momento di invio del link al cliente (null = mai inviato).
  checkoutExpiresAt DateTime?
  linkSentAt        DateTime?

  // Note libere (es. "bonifico ricevuto il 12/06").
  note String?

  // Chi ha registrato il pagamento manuale (null per i pagamenti Stripe).
  recordedById String?
  recordedBy   User?   @relation("PaymentRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  items         PaymentItem[]
  // Ricevuta non fiscale generata alla conferma (1:1).
  receipt       Receipt?
  notifications NotificationLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subscriptionId])
  @@index([status])
  @@map("payments")
}

/// Riga di un pagamento riferita a una singola SubscriptionItem: consente
/// storno parziale e conserva lo snapshot pre-rinnovo per il ripristino.
model PaymentItem {
  id                 String           @id @default(cuid())
  paymentId          String
  payment            Payment          @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  subscriptionItemId String
  subscriptionItem   SubscriptionItem @relation(fields: [subscriptionItemId], references: [id], onDelete: Restrict)

  amountCents Int
  // Stato PER RIGA: consente lo storno parziale di un singolo servizio.
  status      PaymentStatus @default(IN_ATTESA)

  // Periodo coperto da questa riga (utile per il rinnovo).
  periodStart DateTime?
  periodEnd   DateTime?

  // Snapshot pre-rinnovo per questo item specifico (per ripristino su storno).
  previousEndDate       DateTime?
  previousPriceCents    Int?
  previousLastRenewalAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([paymentId])
  @@index([subscriptionItemId])
  @@map("payment_items")
}

// ──────────────────────────────────────────────────────────────────────────
// RICEVUTE NON FISCALI
// ──────────────────────────────────────────────────────────────────────────

/// Ricevuta NON fiscale: pagina HTML pubblica accessibile via token univoco.
/// I dati sono denormalizzati (snapshot) così la ricevuta resta immutabile
/// anche se cliente/servizio cambiano in seguito. Le singole voci di servizio
/// sono righe (ReceiptLine).
model Receipt {
  id String @id @default(cuid())

  paymentId String  @unique
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  // Token pubblico per l'accesso senza autenticazione.
  token  String @unique @default(cuid())
  // Numero progressivo leggibile (es. "RIC-2026-0001").
  number String @unique

  // Snapshot dei dati al momento dell'emissione.
  clientName     String
  ragioneSociale String?
  partitaIva     String?
  codiceFiscale  String?
  clientEmail    String?
  clientAddress  String? // indirizzo completo formattato

  amountCents Int // totale pagato (imponibile + IVA, incluso costo di servizio)
  // Scorporo IVA 22%: imponibile = round(amountCents / 1.22), IVA = totale − imponibile.
  taxableAmountCents Int @default(0)
  vatAmountCents     Int @default(0)
  // Costo di servizio Radar (1,5%) incluso nel totale, mostrato come riga a parte.
  serviceFeeCents    Int @default(0)
  currency    String        @default("eur")
  method      PaymentMethod
  paidAt      DateTime

  // Se valorizzato, la finestra di accesso pubblico (10gg) riparte da qui
  // invece che da issuedAt (riattivazione manuale dell'admin).
  publicAccessResetAt DateTime?

  lines ReceiptLine[]

  issuedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@map("receipts")
}

/// Singola voce di servizio all'interno di una ricevuta (snapshot immutabile).
model ReceiptLine {
  id          String    @id @default(cuid())
  receiptId   String
  receipt     Receipt   @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  serviceName String
  description String?
  periodStart DateTime?
  periodEnd   DateTime?
  // Quantità (snapshot) e importo TOTALE della riga (unitario × quantità).
  quantity    Int       @default(1)
  amountCents Int

  @@index([receiptId])
  @@map("receipt_lines")
}

// ──────────────────────────────────────────────────────────────────────────
// IMPOSTAZIONI REMINDER (configurabili da UI)
// ──────────────────────────────────────────────────────────────────────────

/// Singolo record (singleton, id="singleton") con le soglie temporali dei
/// reminder, rese configurabili. I testi email personalizzati sono in
/// ReminderTemplate (una riga per NotificationType).
model ReminderSettings {
  id                  String @id @default("singleton")
  // Giorni-mancanti alla scadenza per i promemoria di periodi lunghi (annuali).
  thresholdsLongDays  Int[]  @default([30, 15, 7])
  // Idem, riscalati per periodi corti (mensili).
  thresholdsShortDays Int[]  @default([10, 5, 1])
  // Giorni-dopo-la-scadenza in cui inviare un SOLLECITO.
  overdueDays         Int[]  @default([0, 1, 2, 7, 10])
  // Giorno-dopo-la-scadenza in cui scatta la cessazione per morosità.
  cessationDay        Int    @default(11)
  // Ore dalla creazione di una AutoChargeRequest in cui sollecitare l'attivazione
  // (soglia intermedia = reminder al cliente; ultima soglia = escalation admin).
  autoChargeReminderHours Int[] @default([12, 24])

  updatedAt DateTime @updatedAt

  @@map("reminder_settings")
}

/// Override testuale (oggetto/corpo) di una email di reminder, per tipo.
/// Campi null = usa il testo di default (REMINDER_DEFAULTS in email-templates).
model ReminderTemplate {
  type    NotificationType @id
  subject String?
  body    String?

  updatedAt DateTime @updatedAt

  @@map("reminder_templates")
}

// ──────────────────────────────────────────────────────────────────────────
// LOG NOTIFICHE (EMAIL)
// ──────────────────────────────────────────────────────────────────────────

/// Log di ogni email inviata, per tracciabilità ed evitare doppi invii.
model NotificationLog {
  id String @id @default(cuid())

  subscriptionItemId String?
  subscriptionItem   SubscriptionItem? @relation(fields: [subscriptionItemId], references: [id], onDelete: Cascade)

  paymentId String?
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  type      NotificationType
  status    NotificationStatus
  recipient String // email destinatario

  // ID restituito da Resend (per tracciabilità) ed eventuale errore.
  resendId String?
  error    String?

  // Chiave-giorno (YYYY-MM-DD) usata per de-duplicare gli invii giornalieri
  // (es. promemoria/solleciti): un solo invio per tipo/riga/giorno.
  dedupeKey String?

  sentAt    DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([subscriptionItemId, type, dedupeKey])
  @@index([subscriptionItemId])
  @@index([paymentId])
  @@index([type])
  @@map("notification_logs")
}
